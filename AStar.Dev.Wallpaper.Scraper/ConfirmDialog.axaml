<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AStar.Dev.Wallpaper.Scraper.ConfirmDialog"
        Title="Are you sure?"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16" Spacing="16">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" MaxWidth="360" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Yes" MinWidth="75" IsDefault="True" Click="OnYesClick" />
            <Button Content="No" MinWidth="75" IsCancel="True" Click="OnNoClick" />
        </StackPanel>
    </StackPanel>
</Window>
